{
  "buildCommand": "npm run build:web",
  "outputDirectory": "packages/web/dist",
  "framework": "vite",
  "installCommand": "npm install",
  "env": {
    "VITE_API_URL": {
      "description": "API base URL for the web app",
      "required": false,
      "default": "http://localhost:4000"
    }
  }
}
